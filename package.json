{
  "name": "manga-kindle",
  "version": "0.1.0",
  "private": true,
  "description": "Manga & Anime Downloader with Kindle Converter - HakuNeko + KCC",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "build": "npm run build -w packages/scraper && npm run build -w packages/api && npm run build -w packages/web",
    "build:api": "npm run build -w packages/api",
    "build:web": "npm run build -w packages/web",
    "typecheck": "tsc --build",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "db:generate": "npm run db:generate -w packages/api",
    "db:push": "npm run db:push -w packages/api",
    "db:migrate": "npm run db:migrate -w packages/api",
    "test": "npm run test --workspaces --if-present",
    "clean": "rimraf packages/*/dist packages/*/.next packages/*/node_modules/.cache"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  }
}
