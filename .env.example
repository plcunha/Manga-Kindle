# Server
PORT=3001
NODE_ENV=development

# Database (SQLite path relative to packages/api)
DATABASE_URL="file:./manga-kindle.db"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Downloads
DOWNLOAD_DIR="./downloads"
CONVERTED_DIR="./converted"
TEMP_DIR="./temp"

# KCC (Kindle Comic Converter)
KCC_PATH="/usr/local/bin/kcc-c2e"
# Default Kindle device profile: KPW5 (Kindle Paperwhite 5)
KCC_DEVICE_PROFILE="KPW5"

# Rate limiting (ms between requests per source)
RATE_LIMIT_MS=1000

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
